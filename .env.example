# Copy to .env on the runner host (gitignored) and fill in. The private key is
# device-bound: generate one per host in the App's settings, store it locally
# (never synced/committed), and revoke it when the host is retired.
APP_CLIENT_ID=
APP_PRIVATE_KEY_PATH=C:\ProgramData\ci-runner\github-app-key.pem
RUNNER_REPLICAS=2
RUNNER_LABELS=self-hosted-medley
