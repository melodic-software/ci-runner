# Copy to .env on the runner host (gitignored) and fill in. The private key is
# device-bound: generate one per host in the App's settings, keep the .pem in
# your user profile (never synced/committed), revoke it when the host retires.
# APP_PRIVATE_KEY_B64 is that .pem base64-encoded to one line; on Windows:
#   [Convert]::ToBase64String([IO.File]::ReadAllBytes("$env:USERPROFILE\.ci-runner\github-app-key.pem"))
APP_CLIENT_ID=
APP_PRIVATE_KEY_B64=
RUNNER_REPLICAS=2
RUNNER_LABELS=self-hosted-medley
