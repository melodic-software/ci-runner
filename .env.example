# LEGACY MIGRATION EVIDENCE ONLY. DO NOT COPY THIS FILE OR USE IT FOR A NEW
# INSTALLATION. These variables document the retired Compose credential shape
# until the production canary proves cutover and the legacy files are removed.
#
# APP_PRIVATE_KEY_B64 exposed a reusable GitHub App key to the legacy runner
# container through its environment. It predates current-user DPAPI import and
# does not provide the production source-PEM removal transaction. Production
# hosts must use `ci-runner secret import --file PATH`; after cutover, revoke the
# legacy key and delete both the old .env and any legacy plaintext key file.
APP_CLIENT_ID=
APP_PRIVATE_KEY_B64=
RUNNER_REPLICAS=2
RUNNER_LABELS=self-hosted-medley
